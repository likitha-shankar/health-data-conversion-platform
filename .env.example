# -----------------------------
# Platform-wide environment
# -----------------------------
# Service version string exposed in /health responses.
SERVICE_VERSION=1.0.0

# Terminology release pin used in conversion context and audit.
TERMINOLOGY_RELEASE_ID=terminology-v1.0.0

# Feature flag: enable Tier 2 embedding fallback in terminology service.
ENABLE_TIER2_EMBEDDING=true

# Feature flag: enable replay endpoint in orchestrator.
ENABLE_REPLAY_ENDPOINT=true

# -----------------------------
# Network and service endpoints
# -----------------------------
# Public/local orchestrator endpoint used by scripts.
ORCHESTRATOR_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3005

# Internal/downstream service URLs.
HL7_AGENT_URL=http://localhost:3001
TERMINOLOGY_SERVICE_URL=http://localhost:3002
AUDIT_SERVICE_URL=http://localhost:3003
ERROR_BUS_URL=http://localhost:3004

# Comma-separated CORS origins allowed by backend services.
CORS_ORIGINS=http://localhost:3005,http://127.0.0.1:3005,http://dashboard:3005

# -----------------------------
# Ports (per service process)
# -----------------------------
# Each service reads PORT at process start.
# Set these when launching a single service manually.
# PORT=3000  # orchestrator
# PORT=3001  # hl7v2-agent
# PORT=3002  # terminology-service
# PORT=3003  # audit-service
# PORT=3004  # error-bus

# -----------------------------
# PostgreSQL settings
# -----------------------------
# Shared PostgreSQL connection string used by audit-service and error-bus.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/health_platform

# Separate schemas in the same PostgreSQL database.
AUDIT_DB_SCHEMA=audit
ERROR_DB_SCHEMA=error_bus
TERMINOLOGY_DB_SCHEMA=terminology
ORCHESTRATOR_DB_SCHEMA=orchestrator

# Docker Compose PostgreSQL bootstrap values.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=health_platform

# Athena vocabulary loading (terminology-service)
# Directory containing CONCEPT.csv, CONCEPT_RELATIONSHIP.csv, CONCEPT_SYNONYM.csv.
ATHENA_VOCAB_DIR=./data/athena
# Optional direct Athena zip download URL (typically generated from Athena UI).
ATHENA_DOWNLOAD_URL=
# Auto-load vocabulary files into OMOP tables if terminology schema is empty.
TERMINOLOGY_AUTOLOAD_ON_START=true
# Max rows used to build Tier2 index from CONCEPT + CONCEPT_SYNONYM.
TERMINOLOGY_INDEX_MAX_ROWS=5000

# -----------------------------
# Misc service metadata
# -----------------------------
HL7_AGENT_VERSION=1.0.0
# Secret required for /admin/* orchestrator endpoints.
ADMIN_SECRET=dev-admin-secret
# API key auth is enforced on /convert and /conversions/:ingestion_id/replay.

# -----------------------------
# RAILWAY_DEPLOYMENT
# -----------------------------
# Set these in Railway service environment variables.
#
# DATABASE_URL:
# Provided automatically by the Railway PostgreSQL plugin.
#
# Internal service URLs should point to Railway private service addresses:
# ORCHESTRATOR_URL, HL7_AGENT_URL, TERMINOLOGY_SERVICE_URL,
# AUDIT_SERVICE_URL, ERROR_BUS_URL, DASHBOARD_URL
#
# CORS_ORIGINS should include the Railway dashboard public URL.

# -----------------------------
# MLLP listener
# -----------------------------
MLLP_PORT=2575
MLLP_API_KEY=qmemo_local_mllp_demo_key
MLLP_DEFAULT_TARGET_FORMAT=fhir_r4
