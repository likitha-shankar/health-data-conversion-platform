{
  "name": "health-data-conversion-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @platform/contracts && npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "test": "npm run test -ws --if-present",
    "smoke": "node scripts/smoke-test.mjs",
    "test-mllp": "node scripts/test-mllp.mjs",
    "start": "node scripts/start.mjs",
    "demo": "node scripts/demo.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "@types/cors": "^2.8.17"
  }
}
